AETHERIS_APP_NAME=AETHERIS backend
AETHERIS_API_V1_PREFIX=/api/v1
AETHERIS_ENV=development
AETHERIS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AETHERIS_TRUSTED_HOSTS=127.0.0.1,localhost,testserver
AETHERIS_DEFAULT_ROOM_ID=room_void_01
AETHERIS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/aetheris
AETHERIS_REDIS_URL=redis://127.0.0.1:6379/0
AETHERIS_TOKEN_SECRET=development-only-change-me-32-bytes
AETHERIS_TOKEN_EXPIRATION_MINUTES=60

