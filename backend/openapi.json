  "components": {
    "schemas": {
      "ConsentState": {
        "properties": {
          "microphone": {
            "type": "boolean",
            "title": "Microphone",
            "default": false
          },
          "camera": {
            "type": "boolean",
            "title": "Camera",
            "default": false
          },
          "local_biometrics": {
            "type": "boolean",
            "title": "Local Biometrics",
            "default": false
          },
          "audio": {
            "type": "boolean",
            "title": "Audio",
            "default": false
          },
          "presence": {
            "type": "boolean",
            "title": "Presence",
            "default": false
          }
        },
        "type": "object",
        "title": "ConsentState"
      },
      "ConsentUpdateRequest": {
        "properties": {
          "consent": {
            "$ref": "#/components/schemas/ConsentState"
          }
        },
        "type": "object",
        "required": [
          "consent"
        ],
        "title": "ConsentUpdateRequest"
      },
      "ConsentUpdateResponse": {
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "consent": {
            "$ref": "#/components/schemas/ConsentState"
          },
          "world_state": {
            "$ref": "#/components/schemas/WorldStateSchema"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "consent",
          "world_state"
        ],
        "title": "ConsentUpdateResponse"
      },
      "FeatureFlags": {
        "properties": {
          "webgpu_enabled": {
            "type": "boolean",
            "title": "Webgpu Enabled"
          },
          "webgl_fallback_enabled": {
            "type": "boolean",
            "title": "Webgl Fallback Enabled"
          },
          "local_biometrics_enabled": {
            "type": "boolean",
            "title": "Local Biometrics Enabled"
          },
          "audio_reactive_enabled": {
            "type": "boolean",
            "title": "Audio Reactive Enabled"
          },
          "websocket_enabled": {
            "type": "boolean",
            "title": "Websocket Enabled"
          },
          "echoes_enabled": {
            "type": "boolean",
            "title": "Echoes Enabled",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "webgpu_enabled",
          "webgl_fallback_enabled",
          "local_biometrics_enabled",
          "audio_reactive_enabled",
          "websocket_enabled"
        ],
        "title": "FeatureFlags"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "SessionInitRequest": {
        "properties": {
          "locale": {
            "type": "string",
            "maxLength": 16,
            "minLength": 2,
            "title": "Locale"
          },
          "device_class": {
            "type": "string",
            "enum": [
              "desktop",
              "tablet",
              "mobile",
              "unknown"
            ],
            "title": "Device Class"
          },
          "render_mode": {
            "type": "string",
            "enum": [
              "webgpu",
              "webgl",
              "static"
            ],
            "title": "Render Mode"
          },
          "prefers_reduced_motion": {
            "type": "boolean",
            "title": "Prefers Reduced Motion",
            "default": false
          },
          "timezone_offset_minutes": {
            "type": "integer",
            "maximum": 840.0,
            "minimum": -840.0,
            "title": "Timezone Offset Minutes"
          }
        },
        "type": "object",
        "required": [
          "locale",
          "device_class",
          "render_mode",
          "timezone_offset_minutes"
        ],
        "title": "SessionInitRequest"
      },
      "SessionInitResponse": {
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "title": "Expires At"
          },
          "consent": {
            "$ref": "#/components/schemas/ConsentState"
          },
          "feature_flags": {
            "$ref": "#/components/schemas/FeatureFlags"
          },
          "world_state": {
            "$ref": "#/components/schemas/WorldStateSchema"
          },
          "room_id": {
            "type": "string",
            "title": "Room Id"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "access_token",
          "expires_at",
          "consent",
          "feature_flags",
          "world_state",
          "room_id"
        ],
        "title": "SessionInitResponse"
      },
      "SessionMeResponse": {
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "title": "Expires At"
          },
          "consent": {
            "$ref": "#/components/schemas/ConsentState"
          },
          "feature_flags": {
            "$ref": "#/components/schemas/FeatureFlags"
          },
          "world_state": {
            "$ref": "#/components/schemas/WorldStateSchema"
          },
          "room_id": {
            "type": "string",
            "title": "Room Id"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "expires_at",
          "consent",
          "feature_flags",
          "world_state",
          "room_id"
        ],
        "title": "SessionMeResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "WorldRecomputeRequest": {
        "properties": {
          "reason": {
            "type": "string",
            "enum": [
              "manual",
              "presence",
              "interaction"
            ],
            "title": "Reason",
            "default": "manual"
          }
        },
        "type": "object",
        "title": "WorldRecomputeRequest"
      },
      "WorldStateSchema": {
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "void",
              "bloom",
              "nebula",
              "crystal",
              "archive"
            ],
            "title": "Mode"
          },
          "seed": {
            "type": "string",
            "title": "Seed"
          },
          "entropy": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Entropy"
          },
          "fog_density": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Fog Density"
          },
          "bloom_strength": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Bloom Strength"
          },
          "particle_density": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Particle Density"
          },
          "gravity": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Gravity"
          },
          "color_temperature": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Color Temperature"
          },
          "palette": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Palette"
          },
          "typography_weight": {
            "type": "integer",
            "maximum": 900.0,
            "minimum": 100.0,
            "title": "Typography Weight"
          },
          "audio_intensity": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Audio Intensity"
          }
        },
        "type": "object",
        "required": [
          "mode",
          "seed",
          "entropy",
          "fog_density",
          "bloom_strength",
          "particle_density",
          "gravity",
          "color_temperature",
          "palette",
          "typography_weight",
          "audio_intensity"
        ],
        "title": "WorldStateSchema"
      }
    }
  }
}