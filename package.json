{
  "name": "aetheris",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npx concurrently -k -n backend,frontend -c green,blue \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "uv run --directory backend uvicorn app.main:app --reload",
    "dev:frontend": "npm run dev --workspace frontend",
    "build:frontend": "npm run build --workspace frontend",
    "test:frontend": "npm run test --workspace frontend",
    "test:frontend:smoke": "npm run test:smoke --workspace frontend",
    "generate:api-types": "openapi-typescript backend/openapi.json -o frontend/src/generated/api-types.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "openapi-typescript": "^7.10.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}

